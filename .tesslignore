# Files excluded from the published plugin (present in the repo, not shipped).
.git/
.gitignore
.tesslignore
.tessl/
scratch/
scripts/**/tests/
# Fixture-authoring tooling. Lives beside the fixture it generates so a contract change can be
# replayed rather than hand-patched; the eval runner needs the fixture, never the generator.
evals/**/generate.py
__pycache__/
*.pyc
.DS_Store
# CI / dev-only artifacts — not part of the plugin surface (MCP config files stay packageable)
.github/workflows/
.github/dependabot.yml
requirements-dev.txt
pyrightconfig.json
