# Vendored Tessl plugin dependencies — installed at runtime via `tessl install`,
# never committed (see coding-policy rules/dependency-management.md "No Vendoring").
.tessl/plugins/

# Local, machine-specific agent settings
.claude/settings.local.json

# Install-time agent skill links — symlinks into the gitignored vendored tree; they
# would dangle on a fresh clone, so they are never committed. The small static MCP
# config files (.mcp.json, .codex/config.toml, .gemini/settings.json, .*/mcp.json) ARE
# tracked — tessl packages them and they carry no machine-specific state.
.agents/
.claude/skills/
.codex/skills/
.gemini/skills/
.vscode/skills/
.github/skills/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# OS / editor cruft
.DS_Store
*.swp

# A real hub config (user-specific IPs) — the committed template is hubs.example.json
/hubs.json

# Scratch
/scratch/

# Playwright MCP scratch output (contains live hub/device names — never commit)
.playwright-mcp/
