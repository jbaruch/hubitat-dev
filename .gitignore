# Vendored Tessl plugin dependencies — installed at runtime via `tessl install`,
# never committed (see coding-policy rules/dependency-management.md "No Vendoring").
.tessl/plugins/

# Local, machine-specific agent settings
.claude/settings.local.json

# Install-time agent wiring regenerated by `tessl install` — symlinks into the
# gitignored vendored tree and per-agent MCP configs. Not plugin content.
.agents/
.claude/skills/
.codex/
.gemini/
.vscode/
.mcp.json
.github/mcp.json
.github/skills/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# OS / editor cruft
.DS_Store
*.swp

# Scratch
/scratch/
